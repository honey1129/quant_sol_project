# OKX API
OKX_API_KEY=你的APIKey
OKX_SECRET=你的Secret
OKX_PASSWORD=你的Passphrase
OKX_API_MAX_RETRY=3
OKX_API_RETRY_SLEEP_SEC=1
OKX_API_RETRY_BACKOFF=1.5

# 默认使用 OKX 模拟盘 (1=模拟盘，0=实盘)
# 切换实盘前必须确认密钥、仓位模式、杠杆和风控，并将 LIVE_REQUIRE_SIMULATED_TRADING 改为 0。
USE_SERVER=1

# 交易参数
SYMBOL=SOL-USDT-SWAP
LEVERAGE=3
POSITION_SIZE=50

# 多周期
INTERVALS=5m,15m,1H
# 拉长训练窗口(5m≈52天),给模型更多跨价位段的方向样本;平稳特征使跨价位段样本可复用。
WINDOWS=5m:15000,15m:6000,1H:2000
MA_PERIOD=34
RSI_PERIOD=14

# 风控参数
TAKE_PROFIT=0.02
STOP_LOSS=0.01
ADAPTIVE_TP_SL_ENABLED=1
ATR_TAKE_PROFIT_MULTIPLIER=5.0
ATR_STOP_LOSS_MULTIPLIER=2.2
VOLATILITY_TAKE_PROFIT_MULTIPLIER=7.0
VOLATILITY_STOP_LOSS_MULTIPLIER=2.6
ADAPTIVE_TAKE_PROFIT_MIN=0.009
ADAPTIVE_TAKE_PROFIT_MAX=0.045
ADAPTIVE_STOP_LOSS_MIN=0.0055
ADAPTIVE_STOP_LOSS_MAX=0.025
REGIME_HIGH_VOL_STOP_LOSS_MIN=0.009

# 策略阈值
THRESHOLD_LONG=0.56
THRESHOLD_SHORT=0.56

# 合约配置
LOT_SIZE=0.01
TICK_SIZE=0.001


# 模型路径
MODEL_PATH=models/model_okx.pkl

# 信号平滑参数
SMOOTH_ALPHA=0.3

# 模型文件路径 (用分隔符编码)
MODEL_PATHS=lgb_v1:models/lgb_model.pkl,xgb_v1:models/xgb_model.pkl,rf_v1:models/rf_model.pkl

# 模型权重 (同样用分隔符编码)
MODEL_WEIGHTS=lgb_v1:0.5,xgb_v1:0.3,rf_v1:0.2

# 训练/验证/OOS 样本切分
TRAINING_METADATA_PATH=models/training_metadata.json
# label horizon/阈值经 OOS 扫描选定:5m@0.4% 移动高于噪声中位(0.18%~0.28%),
# 比 fw=5/th=0.002(落在噪声里)方向命中率 60% vs 54%、OOS PF 更高。
MODEL_LABEL_FUTURE_WINDOW=8
MODEL_LABEL_THRESHOLD=0.004
# realistic 二分类质量标签: OOS 标签强度校准推荐 lookahead=24, TP=1.6%, SL=1.4%。
# trade 标签要求:规则允许开仓、未来先触发 TP、扣除估算成本后仍有正收益,且 MAE 不超过止损距离。
MODEL_LABEL_USE_REALISTIC=1
MODEL_LABEL_LOOKAHEAD_BARS=24
MODEL_LABEL_TAKE_PROFIT=0.016
MODEL_LABEL_STOP_LOSS=0.014
MODEL_LABEL_MIN_NET_RETURN=0.0
MODEL_LABEL_MAX_MAE_RATIO=1.0
MODEL_LABEL_REQUIRE_REGIME_ALLOWED=1
# 二分类质量标签:1=当前规则方向值得交易,0=不交易;方向仍由 trend/regime 决策层决定。
MODEL_TRAIN_TRADABLE_LABELS=1
MODEL_TRAIN_NO_TRADE_LABELS=1
# 方向质量子模型:long/short 分开学习"该方向内哪些时刻值得交易",避免一套质量模型混淆多空排序。
MODEL_TRAIN_DIRECTION_QUALITY_MODELS=1
MODEL_DIRECTION_QUALITY_MIN_ROWS=200
MODEL_DIRECTION_QUALITY_MIN_TRADE_ROWS=20
MODEL_DIRECTION_QUALITY_CALIBRATION=sigmoid
MODEL_DIRECTION_QUALITY_CALIBRATION_RATIO=0.20
MODEL_DIRECTION_QUALITY_CALIBRATION_MIN_ROWS=50
MODEL_DIRECTION_QUALITY_CALIBRATION_MIN_POSITIVES=5
MODEL_DIRECTION_QUALITY_CALIBRATION_MIN_NEGATIVES=5
MODEL_DIRECTION_QUALITY_CALIBRATION_USE_SAMPLE_WEIGHT=0
MODEL_DIRECTION_QUALITY_REGIME_CALIBRATION=1
MODEL_DIRECTION_QUALITY_REGIME_CALIBRATION_MIN_ROWS=50
MODEL_DIRECTION_QUALITY_REGIME_CALIBRATION_MIN_POSITIVES=5
MODEL_DIRECTION_QUALITY_REGIME_CALIBRATION_MIN_NEGATIVES=5
# 训练不再随机下采样；先平衡 trade/no_trade，再在类别内部按 regime+direction 平衡，并提高近期样本权重。
MODEL_RECENT_SAMPLE_WEIGHT_BOOST=0.5
MODEL_TRADE_SAMPLE_WEIGHT_MULTIPLIER=2.0
MODEL_NO_TRADE_SAMPLE_WEIGHT_MULTIPLIER=1.0
MODEL_SAMPLE_WEIGHT_MIN=0.25
MODEL_SAMPLE_WEIGHT_MAX=20.0
MODEL_TRAIN_RATIO=0.70
MODEL_VALIDATION_RATIO=0.15
# purge gap 应 >= 当前标签 horizon；realistic 标签默认用 MODEL_LABEL_LOOKAHEAD_BARS=24。
MODEL_PURGE_BARS=24
# 评估仍按时间切分；最终保存产物默认使用 OOS 之前的 train+validation 历史段重训。
MODEL_FINAL_TRAIN_ON_VALIDATION=1
MODEL_WALK_FORWARD_ENABLED=1
MODEL_WALK_FORWARD_FOLDS=3
MODEL_WALK_FORWARD_MIN_FOLDS=2
MODEL_WALK_FORWARD_MIN_VALIDATION_ROWS=100
# walk-forward 诊断使用校准后概率尺度；threshold sweep 只输出候选门槛诊断，不会自动改线上阈值。
MODEL_WALK_FORWARD_DIAGNOSTIC_THRESHOLD=0.35
MODEL_WALK_FORWARD_THRESHOLD_SWEEP_ENABLED=1
MODEL_WALK_FORWARD_THRESHOLD_SWEEP_THRESHOLDS=0.12,0.20,0.30,0.40,0.50
MODEL_WALK_FORWARD_THRESHOLD_SWEEP_GAPS=0.00,0.08,0.12
MODEL_WALK_FORWARD_THRESHOLD_SWEEP_MIN_TARGET_RATIOS=0.005,0.010
MODEL_WALK_FORWARD_THRESHOLD_SWEEP_POSITION_CENTERS=0.05,0.10,0.20,0.30
MODEL_WALK_FORWARD_THRESHOLD_SWEEP_MAX_CANDIDATES=160
MODEL_WALK_FORWARD_THRESHOLD_SWEEP_TOP_N=5

# 仓位边界
POSITION_MIN=0.08
POSITION_MAX=0.45
POSITION_PROBABILITY_CENTER=0.45
BASE_POSITION_RATIO=0.12
MAX_POSITION_RATIO=0.45
MIN_ADJUST_AMOUNT=150
ADJUST_UNIT=50
ADD_THRESHOLD=0.25
MAX_REBALANCE_RATIO=0.25
BLOCK_LOSING_POSITION_ADDS=1
DYNAMIC_RISK_ENABLED=0
DYNAMIC_LEVERAGE_MIN=1
DYNAMIC_LEVERAGE_MAX=3
DYNAMIC_POSITION_MAX=0.45
DYNAMIC_RISK_HIGH_VOL_MULTIPLIER=0.65
DYNAMIC_RISK_LOW_SIGNAL_MULTIPLIER=0.60
DYNAMIC_RISK_TREND_MISMATCH_MULTIPLIER=0.50
DYNAMIC_RISK_STRONG_SIGNAL_THRESHOLD=0.30
DYNAMIC_RISK_WEAK_SIGNAL_THRESHOLD=0.16
TRADE_COOLDOWN_BARS=6
SIGNAL_MIN_PROB_DIFF=0.12
MIN_SIGNAL_TARGET_RATIO=0.04
REGIME_RANGE_MIN_SIGNAL_TARGET_RATIO=0.05
REGIME_HIGH_VOL_MIN_SIGNAL_TARGET_RATIO=0.05
# 仅用于离线校准报告；不会直接改变实盘门槛。
REGIME_DIRECTION_CALIBRATION_THRESHOLDS=0.02,0.04,0.06,0.08,0.10,0.15,0.20,0.25,0.30,0.35,0.40,0.45,0.50,0.55,0.60,0.65,0.70,0.75,0.80
REGIME_DIRECTION_CALIBRATION_GAPS=0.00,0.04,0.08,0.12
REGIME_DIRECTION_CALIBRATION_MIN_ROWS=30
REGIME_DIRECTION_CALIBRATION_MIN_TRADES=5
REVERSE_SIGNAL_MIN_PROB_DIFF=0.18
REVERSE_MIN_TARGET_RATIO=0.08
REVERSE_EXIT_CONSECUTIVE_BARS=2
REVERSE_EXIT_MIN_PROB_DIFF=0.28

# 高周期趋势过滤
TREND_FILTER_ENABLED=1
TREND_FILTER_INTERVAL=15m
TREND_FILTER_FAST_COL=ema_20
TREND_FILTER_SLOW_COL=ema_60
TREND_FILTER_MIN_GAP=0.003

# kelly 盈亏比
KELLY_REWARD_RISK=2.8

# 动态风险预算目标波动
TARGET_VOL=0.02
MIN_HOLD_BARS=4
TRAILING_EXIT=0.02

MAX_POSITION=0.4
INITIAL_BALANCE=1000
BACKTEST_MIN_ADJUST_AMOUNT=40
BACKTEST_FORCE_CLOSE_ON_END=1
FEE_RATE=0.0005
BACKTEST_INTRABAR_TP_SL=0

# 实盘/模拟盘保护；默认强制模拟盘，防止复制示例后误连实盘。
LIVE_REQUIRE_SIMULATED_TRADING=1
LIVE_AUTO_SET_POSITION_MODE=1
LIVE_AUTO_SET_LEVERAGE=1
LIVE_RECONCILE_PENDING_ORDERS=1
LIVE_PERSIST_LAST_BAR=1
LIVE_USE_AVAILABLE_MARGIN_FOR_SIZING=1
LIVE_MARGIN_USAGE_RATIO=0.85
LIVE_MIN_FREE_MARGIN_USDT=30
LIVE_REWARD_RISK_MIN=1.2

# 自动模型重训
MODEL_RETRAIN_ENABLED=1
MODEL_RETRAIN_HOUR=3
MODEL_RETRAIN_MINUTE=10
MODEL_RETRAIN_INTERVAL_HOURS=24
MODEL_RETRAIN_VALIDATE_BACKTEST=1
MODEL_RETRAIN_MIN_RETURN_PCT=0.0
MODEL_RETRAIN_MAX_DRAWDOWN_PCT=-5.0
MODEL_RETRAIN_MIN_CLOSED_TRADES=10
MODEL_RETRAIN_MIN_WIN_RATE_PCT=45.0
MODEL_RETRAIN_MIN_PROFIT_FACTOR=1.05
MODEL_RETRAIN_MIN_AVG_WIN_LOSS_RATIO=0.8
MODEL_RETRAIN_MIN_NET_PNL_AFTER_COSTS=0.0
MODEL_RETRAIN_MIN_OOS_ROWS=100
MODEL_RETRAIN_REGIME_GATE_ENABLED=1
MODEL_RETRAIN_REGIME_GATE_MIN_ROWS=30
MODEL_RETRAIN_MAX_TREND_SHORT_LONG_DOMINANCE_PCT=80.0
MODEL_RETRAIN_MAX_TREND_LONG_SHORT_DOMINANCE_PCT=80.0
MODEL_RETRAIN_RESTART_LIVE_MONITOR=1
MODEL_RETRAIN_KEEP_BACKUPS=5


# Telegram通知
TELEGRAM_BOT_TOKEN=你的TG_BOT_TOKEN
TELEGRAM_CHAT_ID=你的TG_CHAT_ID
TELEGRAM_ENABLED=0
TELEGRAM_LOOP_ERROR_NOTIFY_THRESHOLD=3
DAILY_REPORT_HOUR=23
DAILY_REPORT_MINUTE=59


TRAILING_STOP=0.03
MAX_HOLD_BARS=96

POLL_SEC=10
